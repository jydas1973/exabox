      "width": 424,
      "height": 168,
      "text": "\"0x030C0000\": {\n  possible_causes: [\"ASM disks offline\", ...],\n  first_check: \"cellcli -e list griddisk ...\",\n  reschedule_policy: \"reschedule_after_14_days\",\n  cn_template: \"Exadata-3ac\",\n  customer_action_required: False,\n  sample_ticket: \"DBAASOPS-329173\"\n}\n# One structured entry per error code from ops runbook",
