    },
    {
      "type": "text",
      "id": "t_pe_content",
      "x": -139.10435267857156,
      "y": 10.20047433035711,
      "width": 424,
      "height": 180,
      "text": "PATCH_ERRORS = {\n  \"0x03010000\": PatchError(\"Patch op failed.\", EA_FAIL_DONTSHOW),\n  \"0x030F0004\": PatchError(\"CPS op failed.\", EA_FAIL_DONTSHOW),  # CPS fixed\n  \"0x0301003D\": PatchError(\"No action req.\", EA_FAIL_DONTSHOW), # was missing\n  \"0x03030008\": PatchError(\"Heartbeat failed.\", EA_FAIL_DONTSHOW),\n  \"0x03030027\": PatchError(\"CRS disabled.\", EA_FAIL_AND_SHOW),\n  # ...all codes — mGetPatchkey() removed\n}",
      "originalText": "PATCH_ERRORS = {\n  \"0x03010000\": PatchError(\"Patch op failed.\", EA_FAIL_DONTSHOW),\n  \"0x030F0004\": PatchError(\"CPS op failed.\", EA_FAIL_DONTSHOW),  # CPS fixed\n  \"0x0301003D\": PatchError(\"No action req.\", EA_FAIL_DONTSHOW), # was missing\n  \"0x03030008\": PatchError(\"Heartbeat failed.\", EA_FAIL_DONTSHOW),\n  \"0x03030027\": PatchError(\"CRS disabled.\", EA_FAIL_AND_SHOW),\n  # ...all codes — mGetPatchkey() removed\n}",
      "fontSize": 11,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "strokeColor": "#22c55e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 345,
      "version": 498,
      "versionNonce": 531027071,
      "isDeleted": false,
      "groupIds": [],
      "boundElements": [
        {
          "id": "a5",
          "type": "arrow"
        }
      ],
      "link": null,
      "locked": false,
      "containerId": null,
      "lineHeight": 1.25,
      "index": "ai",
      "frameId": null,
