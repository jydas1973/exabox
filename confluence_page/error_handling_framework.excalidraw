    {
      "type": "text",
      "id": "t_pe_title",
      "x": -139.10435267857156,
      "y": -9.07296316964289,
      "width": 424,
      "height": 16,
      "text": "PATCH_ERRORS  —  single flat dict  (replaces 15+ dicts + mGetPatchkey routing)",
      "originalText": "PATCH_ERRORS  —  single flat dict  (replaces 15+ dicts + mGetPatchkey routing)",
      "fontSize": 12,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "strokeColor": "#22c55e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 343,
      "version": 394,
      "versionNonce": 1951348831,
      "isDeleted": false,
      "groupIds": [],
      "boundElements": [],
      "link": null,
      "locked": false,
      "containerId": null,
      "lineHeight": 1.25,
      "index": "ah",
      "frameId": null,
