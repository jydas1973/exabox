    {
      "type": "text",
      "id": "t_patcherror_content",
      "x": -139.10435267857156,
      "y": 233.9270368303571,
      "width": 424,
      "height": 44,
      "text": "PatchError = namedtuple(\"PatchError\", [\"message\", \"action\"])\n# entry.message  ← not [0]      entry.action  ← not [1]",
      "originalText": "PatchError = namedtuple(\"PatchError\", [\"message\", \"action\"])\n# entry.message  ← not [0]      entry.action  ← not [1]",
      "fontSize": 11,
