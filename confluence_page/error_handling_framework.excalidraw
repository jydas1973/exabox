      "width": 424,
      "height": 88,
      "text": "EA_FAIL_DONTSHOW   = \"FAIL_DONTSHOW_PAGE_ONCALL\"\nEA_FAIL_AND_SHOW   = \"FAIL_AND_SHOW\"\nEA_RETRY_SAME      = \"RETRY_WITH_SAME_TOKEN\"\nEA_RETRY_DIFFERENT = \"RETRY_WITH_DIFFERENT_TOKEN\"",
