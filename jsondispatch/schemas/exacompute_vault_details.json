{
    "properties": {
        "exarootuser": {
            "type": "string",
            "pattern": "^[A-Za-z0-9][A-Za-z0-9_.-]{0,62}$",
            "minLength": 1,
            "maxLength": 63
        },
        "exarooturl": {
            "type": "string",
            "pattern": "^([Hh][Tt][Tt][Pp]://|[Hh][Tt][Tt][Pp][Ss]://)[A-Za-z0-9._~:/?#@!$&()*+,=%\\-\\[\\]{}]{1,511}$",
            "minLength": 1,
            "maxLength": 512
        },
        "hostname": {
            "type": "string"
        },
        "vaultaccess": {
            "type": "string"
        },
        "vaultid": {
            "type": "string"
        },
        "trustcertificates": {
            "items": {
                "type": "string"
            },
            "type": "array"
        }
    },
    "required": [
        "exarootuser",
        "exarooturl",
        "hostname",
        "vaultaccess",
        "vaultid",
        "trustcertificates"
    ],
    "type": "object"
}
